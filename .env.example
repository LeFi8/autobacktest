# ==============================================================================
# AutoBacktest Central Configuration Environment Template
# ==============================================================================

# --- LLM CLIENT CONFIGURATION ---
# Target model and provider configurations
AUTOBACKTEST_LLM_PROVIDER=litellm
AUTOBACKTEST_LLM_MODEL=openai/gpt-4o
AUTOBACKTEST_LLM_TEMPERATURE=0.7
AUTOBACKTEST_LLM_MAX_TOKENS=4096

# Enable verbose debug logging in LiteLLM (calls litellm._turn_on_debug())
AUTOBACKTEST_LITELLM_DEBUG=False

# Enable Anthropic-style prompt caching on the stable prefix
AUTOBACKTEST_LLM_PROMPT_CACHE=True

# Default timeout for LLM requests (in seconds)
AUTOBACKTEST_LLM_REQUEST_TIMEOUT=600.0

# API keys (Uncomment and populate as needed. Supported out-of-the-box by LiteLLM)
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GEMINI_API_KEY=your-gemini-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# GROQ_API_KEY=your-groq-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key

# --- BACKTEST DEFAULT WINDOWS ---
# Default date windows for evaluating strategies
AUTOBACKTEST_DEFAULT_START_DATE=2015-01-01
AUTOBACKTEST_DEFAULT_END_DATE=2026-05-29
AUTOBACKTEST_DEFAULT_HOLDOUT_YEARS=3

# --- SYSTEM DIRECTORIES & STORAGE ---
# Local workspace and caching storage directories
AUTOBACKTEST_RUN_DIR=runs
AUTOBACKTEST_CACHE_DIR=data/cache
AUTOBACKTEST_STRATEGIES_DIR=strategies
AUTOBACKTEST_CONFIGS_DIR=configs
AUTOBACKTEST_LEDGER_DB_NAME=ledger.db

# --- DYNAMIC VALIDATION SECURITY GATES ---
# Resource and permission limits for strategy execution
AUTOBACKTEST_MAX_FILE_SIZE_KB=100
AUTOBACKTEST_MAX_CYCLOMATIC_COMPLEXITY=25
AUTOBACKTEST_MAX_FUNCTION_LINES=100
AUTOBACKTEST_ENABLE_LLM_REPAIR=true
AUTOBACKTEST_MAX_REPAIR_ATTEMPTS=2
AUTOBACKTEST_ENABLE_CONFIG_JITTER=true
AUTOBACKTEST_CONFIG_JITTER_MAX_ATTEMPTS=12
AUTOBACKTEST_CONFIG_JITTER_REL_STEP=0.15
AUTOBACKTEST_ENABLE_JSON_SALVAGE=true
AUTOBACKTEST_ENABLE_CANDIDATE_DIRECTIVES=true
AUTOBACKTEST_ENABLE_EXPLORED_CONFIG_INJECTION=true
AUTOBACKTEST_EXPLORED_CONFIG_MAX_CONFIGS=30
AUTOBACKTEST_ENABLE_IDENTICAL_BEHAVIOR_GUARD=true
AUTOBACKTEST_IDENTICAL_BEHAVIOR_EPSILON=1e-6
AUTOBACKTEST_QUIET=false
AUTOBACKTEST_SAFE_IMPORTS_WHITELIST=pandas,numpy,math,typing,scipy,dataclasses,collections,itertools,functools,decimal,statistics,numbers,json

# --- OPTIMIZATION LOOP ---
# Maximum consecutive rejections before early-stop terminates the run.
# Set to 0 to disable early stopping entirely.
AUTOBACKTEST_EARLY_STOP_PATIENCE=10

# Number of candidate variants generated per LLM iteration
AUTOBACKTEST_N_CANDIDATES=3

# Minimum attempts required before importance-weighted diversity activates
AUTOBACKTEST_IMPORTANCE_MIN_ATTEMPTS=6

# Diversity p-value threshold for importance-weighted resampling
AUTOBACKTEST_IMPORTANCE_P_THRESHOLD=0.20

# Sandbox subprocess timeout (seconds) for strategy validation preflight checks
AUTOBACKTEST_SANDBOX_TIMEOUT=15

# Enable automatic pandas deprecated API repair (AST-based codemod)
AUTOBACKTEST_ENABLE_CODEMOD_REPAIR=true

# --- DIVERSITY GATE THRESHOLDS ---
# Enable the config similarity gate in explore mode
AUTOBACKTEST_ENABLE_CONFIG_DIVERSITY_GATE=true

# Config similarity threshold for Tier 1 diversity gate (0.0 - 1.0)
AUTOBACKTEST_DIVERSITY_CONFIG_THRESHOLD=0.95

# Returns correlation threshold for Tier 2 diversity gate (0.0 - 1.0)
AUTOBACKTEST_DIVERSITY_RETURNS_THRESHOLD=0.95

# --- SQLITE STORAGE CONFIGURATION ---
# Database parameters
AUTOBACKTEST_DB_TIMEOUT=15.0
